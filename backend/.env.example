# --- Local development ---
# FRONTEND_URL=http://localhost:5173
# GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# --- Production (Render) ---
FRONTEND_URL=https://stitches-frontend.vercel.app
GOOGLE_CALLBACK_URL=https://stitches-backend.onrender.com/api/auth/google/callback

CLIENT_ID=your_google_client_id
CLIENT_SECRET=your_google_client_secret
MONGO_URI=your_mongodb_connection_string
PORT=5000
NODE_ENV=production
SECRET_KEY=your_session_secret_key
ACCESS_SECRET=your_access_jwt_secret
REFRESH_SECRET=your_refresh_jwt_secret
ACCESS_TOKEN_MAX_AGE=900000
REFRESH_TOKEN_MAX_AGE=604800000
EMAIL=your_email
APP_PASS=your_email_app_password

PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
PAYPAL_MODE=sandbox
PAYPAL_API=https://api-m.sandbox.paypal.com
